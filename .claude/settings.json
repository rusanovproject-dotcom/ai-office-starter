{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "permissions": {
    "deny": [
      "Read(.env)",
      "Read(.env.*)",
      "Read(**/.env)",
      "Read(**/.env.*)",
      "Read(*.pem)",
      "Read(**/*.pem)",
      "Read(credentials*)",
      "Read(**/credentials*)",
      "Read(secrets*)",
      "Read(**/secrets*)",
      "Read(config.env)",
      "Read(**/config.env)",
      "Edit(.env)",
      "Edit(.env.*)",
      "Edit(**/.env)",
      "Edit(**/.env.*)",
      "Write(.env)",
      "Write(.env.*)",
      "Write(**/.env)",
      "Write(**/.env.*)",
      "Edit(*.pem)",
      "Edit(**/*.pem)",
      "Write(*.pem)",
      "Write(**/*.pem)",
      "Edit(credentials*)",
      "Edit(**/credentials*)",
      "Write(credentials*)",
      "Write(**/credentials*)",
      "Edit(secrets*)",
      "Edit(**/secrets*)",
      "Write(secrets*)",
      "Write(**/secrets*)",
      "Edit(config.env)",
      "Edit(**/config.env)",
      "Write(config.env)",
      "Write(**/config.env)",
      "Bash(rm -rf:*)",
      "Bash(rm -fr:*)",

      "Bash(curl:*)",
      "Bash(wget:*)",
      "Bash(scp:*)",
      "Bash(sftp:*)",
      "Bash(rsync:*)",
      "Bash(nc:*)",
      "Bash(ncat:*)",
      "Bash(netcat:*)",
      "Bash(telnet:*)",
      "Bash(ssh:*)",
      "Bash(ftp:*)",
      "Bash(mail:*)",
      "Bash(sendmail:*)",
      "Bash(python3 -c:*)",
      "Bash(python -c:*)",
      "Bash(node -e:*)",
      "Bash(perl -e:*)",
      "Bash(ruby -e:*)",
      "Bash(gh gist:*)",
      "Bash(gh api:*)",
      "Bash(gh repo create:*)",
      "Bash(*--dangerously-skip-permissions*)",

      "Bash(git remote add:*)",
      "Bash(git remote set-url:*)",
      "Bash(git -c:*)",
      "Bash(git config core.hooksPath:*)",
      "Bash(git config*hooksPath*)",
      "Bash(git push --no-verify:*)",
      "Bash(git push*--no-verify*)",
      "Bash(git push --force:*)",
      "Bash(git push*--force*)",
      "Bash(git push --force-with-lease:*)",
      "Bash(git reset --hard:*)"
    ]
  },
  "hooks": {
    "SessionStart": [
      {
        "matcher": "startup|clear",
        "hooks": [
          {
            "type": "command",
            "command": "bash \"${CLAUDE_PROJECT_DIR:-.}/.claude/hooks/pd-gate-install.sh\""
          },
          {
            "type": "command",
            "command": "bash \"${CLAUDE_PROJECT_DIR:-.}/.claude/hooks/git-safety.sh\" snapshot"
          },
          {
            "type": "command",
            "command": "bash \"${CLAUDE_PROJECT_DIR:-.}/.claude/hooks/session-load.sh\""
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash \"${CLAUDE_PROJECT_DIR:-.}/.claude/hooks/prompt-inject.sh\""
          }
        ]
      }
    ]
  }
}
